# HealthStay — Optional Supabase Configuration
#
# These variables are optional for local prototype mode.
# If missing, the app uses static fallback data.
#
# Get these values from your Supabase project dashboard:
#   Settings > API > Project URL (NEXT_PUBLIC_SUPABASE_URL)
#   Settings > API > anon/public key (NEXT_PUBLIC_SUPABASE_ANON_KEY)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
